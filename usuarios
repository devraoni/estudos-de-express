const express = require('express');
const app = express();
const usuariosRoutes = require('./routes/usuarios'); // Ajuste o caminho se necessário

app.use('/usuarios', usuariosRoutes);

// Rota raiz para não dar "Cannot GET /"
app.get('/', (req, res) => {
    res.send('Servidor OK! Tente acessar /usuarios');
});

app.listen(3000, () => {
    console.log("Servidor rodando em http://localhost:3000");
});
